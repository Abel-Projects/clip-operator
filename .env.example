# --- Required for the default autopilot pipeline (SupoClip + YouTube) ---

# YouTube Data API — powers autopilot source discovery
YOUTUBE_API_KEY=

# Autopilot database (create a dedicated Supabase project — see README)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Protect the cron endpoint (trigger sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# SupoClip (default clip engine — self-hosted on your home server)
# Local dev: http://localhost:8000
# Vercel production: Tailscale Funnel URL to home server :8000 (see deploy/README.md)
SUPOCLIP_BASE_URL=http://localhost:8000
SUPOCLIP_FRONTEND_URL=http://localhost:3107
SUPOCLIP_USER_ID=
SUPOCLIP_AUTH_SECRET=supoclip_dev_backend_secret_change_me

# Home-server TikTok publisher agent auth (defaults to CRON_SECRET if unset)
# PUBLISH_AGENT_SECRET=

# Site password (in-app unlock form + API middleware)
APP_PASSWORD=

# --- Optional: WayinVideo fallback clip engine (cloud API, paid) ---
# WAYINVIDEO_API_KEY=
# WAYINVIDEO_TIKTOK_ACCOUNT_ID=

# --- Optional / legacy providers (not used by default autopilot) ---
# OPUSCLIP_API_KEY=
# OPUSCLIP_ORG_ID=
# OPUSCLIP_POST_ACCOUNT_ID=
# OPUSCLIP_SUB_ACCOUNT_ID=
