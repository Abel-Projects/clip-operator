# OpusClip (required for autopilot)
OPUSCLIP_API_KEY=
# OPUSCLIP_ORG_ID=
# OPUSCLIP_POST_ACCOUNT_ID=
# OPUSCLIP_SUB_ACCOUNT_ID=

# Autopilot database (create a dedicated Supabase project — see README)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Protect cron endpoint (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# WayinVideo (manual workbench only — optional)
WAYINVIDEO_API_KEY=
# WAYINVIDEO_TIKTOK_ACCOUNT_ID=

# SupoClip (self-hosted — manual workbench only)
# SUPOCLIP_BASE_URL=http://localhost:8000
# SUPOCLIP_FRONTEND_URL=http://localhost:3107
# SUPOCLIP_USER_ID=
# SUPOCLIP_AUTH_SECRET=supoclip_dev_backend_secret_change_me

# Site password (in-app unlock form)
# APP_PASSWORD=
