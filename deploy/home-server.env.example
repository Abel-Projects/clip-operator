# Copy to deploy/home-server.env (gitignored) on each dev machine.
# Used by deploy/remote.ps1 and deploy/remote.sh

# SSH host from ~/.ssh/config (see deploy/ssh-config.example)
HOME_SERVER_SSH_HOST=clip-home

# Path to clip-operator on the home server
HOME_SERVER_REPO_PATH=C:/clip-operator

# Optional overrides (defaults come from SSH config)
# HOME_SERVER_USER=hunte
