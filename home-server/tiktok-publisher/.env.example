# Clip Operator app (same machine when self-hosted)
CLIP_OPERATOR_URL=http://localhost:3000

# Auth — must match clip-operator CRON_SECRET or PUBLISH_AGENT_SECRET
PUBLISH_AGENT_SECRET=
CRON_SECRET=

# SupoClip on the same home server
SUPOCLIP_BASE_URL=http://localhost:8000
SUPOCLIP_USER_ID=
SUPOCLIP_AUTH_SECRET=

# --- Upload backend (pick one) ---

# Recommended: TikTokAutoUploader (fast HTTP uploads, ~3s)
# Run setup-uploader.ps1 / setup-uploader.sh once, then:
#   python cli.py login -n my_account   (in vendor/TiktokAutoUploader)
TIKTOK_ACCOUNT_NAME=

# Legacy fallback: Playwright + cookies.txt (slow, needs headed browser)
# TIKTOK_COOKIES_PATH=cookies.txt

# Poll interval when running run-loop (seconds)
POLL_INTERVAL_SEC=300
UPLOAD_TIMEOUT_SEC=120
